# 服务器版 gcal<->atimelogger 同步：复制为 .env 并填入真实值
# 放在 scripts/gcal-atimelogger-sync.mjs 同目录，或用 ENV_FILE 指定路径

# ---- Google Calendar API (OAuth, 需写权限 scope: calendar) ----
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REFRESH_TOKEN=your-google-oauth-refresh-token
GCAL_CALENDAR_ID=primary

# ---- aTimeLogger ----
ATIMELOGGER_BASE_URL=https://app.atimelogger.pro
ATIMELOGGER_USERNAME=your-atimelogger-username
ATIMELOGGER_PASSWORD=your-atimelogger-password
# 或者用 token（配置后优先）：
# ATIMELOGGER_TOKEN=your-atimelogger-bearer-token
# 日历事件写入 aTimeLogger 时使用的活动类型（可填分组名）
ATIMELOGGER_ACTIVITY_TYPE_NAME=工作

# ---- 同步行为 ----
# both / gcal-to-atl / atl-to-gcal
SYNC_DIRECTION=both
SYNC_TIMEZONE=Asia/Shanghai
GCAL_ATL_LOOKBACK_DAYS=1
GCAL_ATL_LOOKAHEAD_DAYS=1
# 第一次建议先设 true 试跑，确认无误再改 false
GCAL_DRY_RUN=true
